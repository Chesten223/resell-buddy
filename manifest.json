{
  "manifest_version": 3,
  "name": "ResellBuddy - Poshmark & Mercari Automation",
  "version": "1.2.0",
  "description": "Automate your reselling on Poshmark & Mercari: auto-share, auto-like, bulk listing, price drops, and more. Save hours every day.",
  "permissions": ["activeTab", "storage", "scripting"],
  "host_permissions": [
    "https://poshmark.com/*",
    "https://www.mercari.com/*",
    "https://www.depop.com/*"
  ],
  "action": {
    "default_popup": "src/popup.html",
    "default_icon": {
      "16": "icons/icon16.png",
      "48": "icons/icon48.png",
      "128": "icons/icon128.png"
    }
  },
  "content_scripts": [
    {
      "matches": ["https://poshmark.com/*"],
      "js": ["src/poshmark.js"],
      "css": ["src/styles.css"]
    },
    {
      "matches": ["https://www.mercari.com/*"],
      "js": ["src/mercari.js"],
      "css": ["src/styles.css"]
    }
  ],
  "background": {
    "service_worker": "src/background.js"
  },
  "icons": {
    "16": "icons/icon16.png",
    "48": "icons/icon48.png",
    "128": "icons/icon128.png"
  }
}
